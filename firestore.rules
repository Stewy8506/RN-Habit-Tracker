rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserPath(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validTask(data) {
      return data.keys().hasOnly([
          'title',
          'completed',
          'createdAt',
          'pomodoroCount',
          'deadline'
        ])
        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 160
        && data.completed is bool
        && data.createdAt is timestamp
        && data.pomodoroCount is int
        && data.pomodoroCount >= 0
        && (data.deadline == null || data.deadline is timestamp);
    }

    function validHabit(data) {
      return data.keys().hasOnly([
          'name',
          'streak',
          'lastCompleted'
        ])
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 120
        && data.streak is int
        && data.streak >= 0
        && (data.lastCompleted == null || data.lastCompleted is timestamp);
    }

    function validSession(data) {
      return data.keys().hasOnly([
          'taskId',
          'duration',
          'completed',
          'createdAt'
        ])
        && (data.taskId == null || data.taskId is string)
        && data.duration is int
        && data.duration > 0
        && data.duration <= 86400
        && data.completed is bool
        && data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow read, create, update: if ownsUserPath(userId);
      allow delete: if false;

      match /tasks/{taskId} {
        allow read, delete: if ownsUserPath(userId);
        allow create, update: if ownsUserPath(userId) && validTask(request.resource.data);
      }

      match /habits/{habitId} {
        allow read, delete: if ownsUserPath(userId);
        allow create, update: if ownsUserPath(userId) && validHabit(request.resource.data);
      }

      match /sessions/{sessionId} {
        allow read: if ownsUserPath(userId);
        allow create: if ownsUserPath(userId) && validSession(request.resource.data);
        allow update, delete: if false;
      }
    }
  }
}
