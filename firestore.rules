rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================
    // Auth Helpers
    // =========================

    function signedIn() {
      return request.auth != null;
    }

    function ownsUserPath(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // =========================
    // User Settings Validation
    // =========================

    function validUserSettings(data) {
      return data.keys().hasOnly([
          'focusDurationSeconds',
          'shortBreakDurationSeconds',
          'longBreakDurationSeconds',
          'longBreakInterval',
          'updatedAt'
        ])

        && (data.focusDurationSeconds == null ||
            (data.focusDurationSeconds is int &&
             data.focusDurationSeconds > 0 &&
             data.focusDurationSeconds <= 14400))

        && (data.shortBreakDurationSeconds == null ||
            (data.shortBreakDurationSeconds is int &&
             data.shortBreakDurationSeconds > 0 &&
             data.shortBreakDurationSeconds <= 3600))

        && (data.longBreakDurationSeconds == null ||
            (data.longBreakDurationSeconds is int &&
             data.longBreakDurationSeconds > 0 &&
             data.longBreakDurationSeconds <= 7200))

        && (data.longBreakInterval == null ||
            (data.longBreakInterval is int &&
             data.longBreakInterval > 0 &&
             data.longBreakInterval <= 20))

        && (data.updatedAt == null ||
            data.updatedAt is timestamp);
    }

    function validUserSettingsUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();

      return changed.hasOnly([
          'focusDurationSeconds',
          'shortBreakDurationSeconds',
          'longBreakDurationSeconds',
          'longBreakInterval',
          'updatedAt'
        ])

        && (!changed.hasAny(['focusDurationSeconds']) ||
            (request.resource.data.focusDurationSeconds is int &&
             request.resource.data.focusDurationSeconds > 0 &&
             request.resource.data.focusDurationSeconds <= 14400))

        && (!changed.hasAny(['shortBreakDurationSeconds']) ||
            (request.resource.data.shortBreakDurationSeconds is int &&
             request.resource.data.shortBreakDurationSeconds > 0 &&
             request.resource.data.shortBreakDurationSeconds <= 3600))

        && (!changed.hasAny(['longBreakDurationSeconds']) ||
            (request.resource.data.longBreakDurationSeconds is int &&
             request.resource.data.longBreakDurationSeconds > 0 &&
             request.resource.data.longBreakDurationSeconds <= 7200))

        && (!changed.hasAny(['longBreakInterval']) ||
            (request.resource.data.longBreakInterval is int &&
             request.resource.data.longBreakInterval > 0 &&
             request.resource.data.longBreakInterval <= 20))

        && (!changed.hasAny(['updatedAt']) ||
            request.resource.data.updatedAt is timestamp);
    }

    // =========================
    // Task Validation
    // =========================

    function validTask(data) {
      return data.keys().hasOnly([
          'title',
          'completed',
          'createdAt',
          'pomodoroCount',
          'deadline',
          'durationMinutes',
          'timeSpentSeconds',
          'icon',
          'priority',
          'timerType'
        ])

        && data.keys().hasAll([
          'title',
          'completed',
          'createdAt',
          'pomodoroCount',
          'timeSpentSeconds'
        ])

        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 160

        && data.completed is bool

        && (data.createdAt == null ||
            data.createdAt is timestamp)

        && data.pomodoroCount is int
        && data.pomodoroCount >= 0

        && data.timeSpentSeconds is int
        && data.timeSpentSeconds >= 0

        && (data.deadline == null ||
            data.deadline is timestamp)

        && (data.durationMinutes == null ||
            (data.durationMinutes is int &&
             data.durationMinutes > 0 &&
             data.durationMinutes <= 1440))

        && (data.icon == null ||
            (data.icon is string &&
             data.icon.size() <= 40))

        && (data.priority == null ||
            data.priority in ['low', 'medium', 'high'])

        && (data.timerType == null ||
            data.timerType in ['pomodoro', 'regular']);
    }

    function validTaskUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();

      return changed.hasOnly([
          'title',
          'completed',
          'pomodoroCount',
          'deadline',
          'durationMinutes',
          'timeSpentSeconds',
          'icon',
          'priority',
          'timerType'
        ])

        && (!changed.hasAny(['title']) ||
            (request.resource.data.title is string &&
             request.resource.data.title.size() > 0 &&
             request.resource.data.title.size() <= 160))

        && (!changed.hasAny(['completed']) ||
            request.resource.data.completed is bool)

        && (!changed.hasAny(['pomodoroCount']) ||
            (request.resource.data.pomodoroCount is int &&
             request.resource.data.pomodoroCount >= 0))

        && (!changed.hasAny(['timeSpentSeconds']) ||
            (request.resource.data.timeSpentSeconds is int &&
             request.resource.data.timeSpentSeconds >= 0))

        && (!changed.hasAny(['deadline']) ||
            request.resource.data.deadline == null ||
            request.resource.data.deadline is timestamp)

        && (!changed.hasAny(['durationMinutes']) ||
            request.resource.data.durationMinutes == null ||
            (request.resource.data.durationMinutes is int &&
             request.resource.data.durationMinutes > 0 &&
             request.resource.data.durationMinutes <= 1440))

        && (!changed.hasAny(['icon']) ||
            request.resource.data.icon == null ||
            (request.resource.data.icon is string &&
             request.resource.data.icon.size() <= 40))

        && (!changed.hasAny(['priority']) ||
            request.resource.data.priority == null ||
            request.resource.data.priority in ['low', 'medium', 'high'])

        && (!changed.hasAny(['timerType']) ||
            request.resource.data.timerType == null ||
            request.resource.data.timerType in ['pomodoro', 'regular']);
    }

    // =========================
    // Habit Validation
    // =========================

    function validHabit(data) {
      return data.keys().hasOnly([
          'name',
          'streak',
          'lastCompleted',
          'icon',
          'priority',
          'category',
          'durationMinutes',
          'timerType'
        ])

        && data.keys().hasAll([
          'name',
          'streak'
        ])

        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 120

        && data.streak is int
        && data.streak >= 0

        && (data.lastCompleted == null ||
            data.lastCompleted is timestamp)

        && (data.icon == null ||
            (data.icon is string &&
             data.icon.size() <= 40))

        && (data.priority == null ||
            data.priority in ['low', 'medium', 'high'])

        && (data.category == null ||
            (data.category is string &&
             data.category.size() <= 40))

        && (data.durationMinutes == null ||
            (data.durationMinutes is int &&
             data.durationMinutes > 0 &&
             data.durationMinutes <= 1440))

        && (data.timerType == null ||
            data.timerType in ['pomodoro', 'regular']);
    }

    function validHabitUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();

      return changed.hasOnly([
          'name',
          'streak',
          'lastCompleted',
          'icon',
          'priority',
          'category',
          'durationMinutes',
          'timerType'
        ])

        && (!changed.hasAny(['name']) ||
            (request.resource.data.name is string &&
             request.resource.data.name.size() > 0 &&
             request.resource.data.name.size() <= 120))

        && (!changed.hasAny(['streak']) ||
            (request.resource.data.streak is int &&
             request.resource.data.streak >= 0))

        && (!changed.hasAny(['lastCompleted']) ||
            request.resource.data.lastCompleted == null ||
            request.resource.data.lastCompleted is timestamp)

        && (!changed.hasAny(['icon']) ||
            request.resource.data.icon == null ||
            (request.resource.data.icon is string &&
             request.resource.data.icon.size() <= 40))

        && (!changed.hasAny(['priority']) ||
            request.resource.data.priority == null ||
            request.resource.data.priority in ['low', 'medium', 'high'])

        && (!changed.hasAny(['category']) ||
            request.resource.data.category == null ||
            (request.resource.data.category is string &&
             request.resource.data.category.size() <= 40))

        && (!changed.hasAny(['durationMinutes']) ||
            request.resource.data.durationMinutes == null ||
            (request.resource.data.durationMinutes is int &&
             request.resource.data.durationMinutes > 0 &&
             request.resource.data.durationMinutes <= 1440))

        && (!changed.hasAny(['timerType']) ||
            request.resource.data.timerType == null ||
            request.resource.data.timerType in ['pomodoro', 'regular']);
    }

    // =========================
    // Session Validation
    // =========================

    function validSession(data) {
      return data.keys().hasOnly([
          'taskId',
          'duration',
          'completed',
          'createdAt'
        ])

        && data.keys().hasAll([
          'duration',
          'completed',
          'createdAt'
        ])

        && (data.taskId == null ||
            (data.taskId is string &&
             data.taskId.size() <= 100))

        && data.duration is int
        && data.duration > 0
        && data.duration <= 86400

        && data.completed is bool

        && (data.createdAt == null ||
            data.createdAt is timestamp);
    }

    // =========================
    // Users
    // =========================

    match /users/{userId} {

      allow read:
        if ownsUserPath(userId);

      allow create:
        if ownsUserPath(userId)
        && validUserSettings(request.resource.data);

      allow update:
        if ownsUserPath(userId)
        && (validUserSettings(request.resource.data) || validUserSettingsUpdate());

      allow delete:
        if false;

      // =========================
      // Tasks
      // =========================

      match /tasks/{taskId} {

        allow read, delete:
          if ownsUserPath(userId);

        allow create:
          if ownsUserPath(userId)
          && validTask(request.resource.data);

        allow update:
          if ownsUserPath(userId)
          && (validTask(request.resource.data) || validTaskUpdate());
      }

      // =========================
      // Habits
      // =========================

      match /habits/{habitId} {

        allow read, delete:
          if ownsUserPath(userId);

        allow create:
          if ownsUserPath(userId)
          && validHabit(request.resource.data);

        allow update:
          if ownsUserPath(userId)
          && (validHabit(request.resource.data) || validHabitUpdate());
      }

      // =========================
      // Sessions
      // =========================

      match /sessions/{sessionId} {

        allow read:
          if ownsUserPath(userId);

        allow create:
          if ownsUserPath(userId)
          && validSession(request.resource.data);

        allow update, delete:
          if false;
      }
    }
  }
}
