rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================
    // Auth Helpers
    // =========================

    function signedIn() {
      return request.auth != null;
    }

    function ownsUserPath(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // =========================
    // User Settings Validation
    // =========================

    function validUserSettings(data) {
      return data.keys().hasOnly([
          'focusDurationSeconds',
          'shortBreakDurationSeconds',
          'longBreakDurationSeconds',
          'longBreakInterval',
          'updatedAt'
        ])

        && (data.focusDurationSeconds == null ||
            (data.focusDurationSeconds is int &&
             data.focusDurationSeconds > 0 &&
             data.focusDurationSeconds <= 14400))

        && (data.shortBreakDurationSeconds == null ||
            (data.shortBreakDurationSeconds is int &&
             data.shortBreakDurationSeconds > 0 &&
             data.shortBreakDurationSeconds <= 3600))

        && (data.longBreakDurationSeconds == null ||
            (data.longBreakDurationSeconds is int &&
             data.longBreakDurationSeconds > 0 &&
             data.longBreakDurationSeconds <= 7200))

        && (data.longBreakInterval == null ||
            (data.longBreakInterval is int &&
             data.longBreakInterval > 0 &&
             data.longBreakInterval <= 20))

        && (data.updatedAt == null ||
            data.updatedAt is timestamp);
    }

    // =========================
    // Task Validation
    // =========================

    function validTask(data) {
      return data.keys().hasOnly([
          'title',
          'completed',
          'createdAt',
          'pomodoroCount',
          'deadline',
          'durationMinutes',
          'timeSpentSeconds',
          'icon',
          'priority',
          'timerType'
        ])

        && data.keys().hasAll([
          'title',
          'completed',
          'createdAt',
          'pomodoroCount',
          'timeSpentSeconds'
        ])

        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 160

        && data.completed is bool

        && (data.createdAt == null ||
            data.createdAt is timestamp)

        && data.pomodoroCount is int
        && data.pomodoroCount >= 0

        && data.timeSpentSeconds is int
        && data.timeSpentSeconds >= 0

        && (data.deadline == null ||
            data.deadline is timestamp)

        && (data.durationMinutes == null ||
            (data.durationMinutes is int &&
             data.durationMinutes > 0 &&
             data.durationMinutes <= 1440))

        && (data.icon == null ||
            (data.icon is string &&
             data.icon.size() <= 40))

        && (data.priority == null ||
            data.priority in ['low', 'medium', 'high'])

        && (data.timerType == null ||
            data.timerType in ['pomodoro', 'regular']);
    }

    // =========================
    // Habit Validation
    // =========================

    function validHabit(data) {
      return data.keys().hasOnly([
          'name',
          'streak',
          'lastCompleted',
          'icon',
          'priority',
          'category',
          'durationMinutes',
          'timerType'
        ])

        && data.keys().hasAll([
          'name',
          'streak'
        ])

        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 120

        && data.streak is int
        && data.streak >= 0

        && (data.lastCompleted == null ||
            data.lastCompleted is timestamp)

        && (data.icon == null ||
            (data.icon is string &&
             data.icon.size() <= 40))

        && (data.priority == null ||
            data.priority in ['low', 'medium', 'high'])

        && (data.category == null ||
            (data.category is string &&
             data.category.size() <= 40))

        && (data.durationMinutes == null ||
            (data.durationMinutes is int &&
             data.durationMinutes > 0 &&
             data.durationMinutes <= 1440))

        && (data.timerType == null ||
            data.timerType in ['pomodoro', 'regular']);
    }

    // =========================
    // Session Validation
    // =========================

    function validSession(data) {
      return data.keys().hasOnly([
          'taskId',
          'duration',
          'completed',
          'createdAt'
        ])

        && data.keys().hasAll([
          'duration',
          'completed',
          'createdAt'
        ])

        && (data.taskId == null ||
            (data.taskId is string &&
             data.taskId.size() <= 100))

        && data.duration is int
        && data.duration > 0
        && data.duration <= 86400

        && data.completed is bool

        && (data.createdAt == null ||
            data.createdAt is timestamp);
    }

    // =========================
    // Users
    // =========================

    match /users/{userId} {

      allow read:
        if ownsUserPath(userId);

      allow create, update:
        if ownsUserPath(userId)
        && validUserSettings(request.resource.data);

      allow delete:
        if false;

      // =========================
      // Tasks
      // =========================

      match /tasks/{taskId} {

        allow read, delete:
          if ownsUserPath(userId);

        allow create, update:
          if ownsUserPath(userId)
          && validTask(request.resource.data);
      }

      // =========================
      // Habits
      // =========================

      match /habits/{habitId} {

        allow read, delete:
          if ownsUserPath(userId);

        allow create, update:
          if ownsUserPath(userId)
          && validHabit(request.resource.data);
      }

      // =========================
      // Sessions
      // =========================

      match /sessions/{sessionId} {

        allow read:
          if ownsUserPath(userId);

        allow create:
          if ownsUserPath(userId)
          && validSession(request.resource.data);

        allow update, delete:
          if false;
      }
    }
  }
}